{
  "stryker-config": {
    "reporters": ["html", "json", "progress"],
    "test-runner": "vstest",
    "project": "Zebrahoof EMR.csproj",
    "test-projects": [
      "Zebrahoof.EMR.UnitTests",
      "Zebrahoof.EMR.ApiTests"
    ],
    "thresholds": {
      "high": 95,
      "low": 85,
      "break": 80
    },
    "ignore-methods": ["*.ToString()", "*.Equals(*)", "*.GetHashCode()", "*.Dispose()"],
    "verbosity": "info",
    "concurrency": 4
  }
}
