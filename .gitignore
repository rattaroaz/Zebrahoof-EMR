# Build outputs
[Bb]in/
[Oo]bj/
[Oo]ut/

# If `dotnet build -o %TEMP%...` is run with a non-expanded %TEMP%, a folder literally named
# "%TEMP%" can appear at the repo root. Never track it.
%TEMP%/
[Ll]og/
[Ll]ogs/
artifacts/

