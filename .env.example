GROK_API_KEY=
# Multi-agent research model (Responses API /v1/responses only)
GROK_MODEL=grok-4.20-multi-agent
# Optional: persist conversation on xAI servers (default false; safer for clinical workloads)
# GROK_STORE=false
# For multi-agent: low|medium = ~4 agents, high|xhigh = ~16 agents (more cost/latency)
# GROK_REASONING_EFFORT=low
# Comma-separated server-side tools (multi-agent): web_search, x_search, code_execution, collections_search
# GROK_SERVER_TOOLS=web_search,x_search
