@page "/admin/templates"
@using Zebrahoof_EMR.Models
@inject MockClinicalDataService ClinicalDataService
@inject ISnackbar Snackbar

<PageTitle>Templates & Order Sets - Zebrahoof EMR</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
    <MudTabPanel Text="Note Templates" Icon="@Icons.Material.Filled.Description">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">Note Templates</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenTemplateDialog">
                Add Template
            </MudButton>
        </MudStack>

        <MudDataGrid T="NoteTemplate" Items="@_templates" Dense="true" Hover="true" Striped="true">
            <Columns>
                <PropertyColumn Property="x => x.Name" Title="Name" />
                <PropertyColumn Property="x => x.Category" Title="Category" />
                <PropertyColumn Property="x => x.VisitType" Title="Visit Type" />
                <PropertyColumn Property="x => x.CreatedBy" Title="Created By" />
                <TemplateColumn Title="Created">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">@context.Item.CreatedAt.ToString("MM/dd/yyyy")</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Shared">
                    <CellTemplate>
                        <MudIcon Icon="@(context.Item.IsShared ? Icons.Material.Filled.Public : Icons.Material.Filled.Person)" 
                                 Size="Size.Small" Color="@(context.Item.IsShared ? Color.Primary : Color.Default)" />
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions" CellStyle="width: 120px;">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" 
                                       OnClick="@(() => ViewTemplate(context.Item))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" 
                                       OnClick="@(() => EditTemplate(context.Item))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudTabPanel>

    <MudTabPanel Text="Smart Phrases" Icon="@Icons.Material.Filled.TextSnippet">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">Smart Phrases</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenPhraseDialog">
                Add Phrase
            </MudButton>
        </MudStack>

        <MudDataGrid T="SmartPhrase" Items="@_smartPhrases" Dense="true" Hover="true" Striped="true">
            <Columns>
                <PropertyColumn Property="x => x.Name" Title="Name" />
                <TemplateColumn Title="Abbreviation">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Item.Abbreviation</MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Category" Title="Category" />
                <TemplateColumn Title="Preview">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="text-truncate" Style="max-width: 300px;">
                            @(context.Item.Content.Length > 50 ? context.Item.Content[..50] + "..." : context.Item.Content)
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Shared">
                    <CellTemplate>
                        <MudIcon Icon="@(context.Item.IsShared ? Icons.Material.Filled.Public : Icons.Material.Filled.Person)" 
                                 Size="Size.Small" Color="@(context.Item.IsShared ? Color.Primary : Color.Default)" />
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions" CellStyle="width: 80px;">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudTabPanel>

    <MudTabPanel Text="Order Sets" Icon="@Icons.Material.Filled.PlaylistAddCheck">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6">Order Sets</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenOrderSetDialog">
                Add Order Set
            </MudButton>
        </MudStack>

        <MudDataGrid T="OrderSet" Items="@_orderSets" Dense="true" Hover="true" Striped="true">
            <Columns>
                <PropertyColumn Property="x => x.Name" Title="Name" />
                <PropertyColumn Property="x => x.Category" Title="Category" />
                <PropertyColumn Property="x => x.Description" Title="Description" />
                <TemplateColumn Title="Items">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small">@context.Item.Items.Count orders</MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.CreatedBy" Title="Created By" />
                <TemplateColumn Title="Shared">
                    <CellTemplate>
                        <MudIcon Icon="@(context.Item.IsShared ? Icons.Material.Filled.Public : Icons.Material.Filled.Person)" 
                                 Size="Size.Small" Color="@(context.Item.IsShared ? Color.Primary : Color.Default)" />
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions" CellStyle="width: 120px;">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" 
                                       OnClick="@(() => ViewOrderSet(context.Item))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudTabPanel>
</MudTabs>

<MudDialog @bind-Visible="_showTemplateDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingTemplate?.Id > 0 ? "Edit Template" : "Add Template")</MudText>
    </TitleContent>
    <DialogContent>
        @if (_editingTemplate != null)
        {
            <MudStack Spacing="2">
                <MudTextField T="string" @bind-Value="_editingTemplate.Name" Label="Name" Variant="Variant.Outlined" Required="true" />
                <MudStack Row="true" Spacing="2">
                    <MudTextField T="string" @bind-Value="_editingTemplate.Category" Label="Category" Variant="Variant.Outlined" />
                    <MudTextField T="string" @bind-Value="_editingTemplate.VisitType" Label="Visit Type" Variant="Variant.Outlined" />
                </MudStack>
                <MudTextField T="string" @bind-Value="_editingTemplate.Content" Label="Template Content" 
                              Variant="Variant.Outlined" Lines="12" />
                <MudSwitch T="bool" @bind-Value="_editingTemplate.IsShared" Label="Share with all users" Color="Color.Primary" />
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showTemplateDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveTemplate">Save</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showViewDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">@_viewTitle</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Style="white-space: pre-wrap; font-family: monospace;">@_viewContent</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showViewDialog = false)">Close</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showOrderSetDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">Order Set Details</MudText>
    </TitleContent>
    <DialogContent>
        @if (_viewingOrderSet != null)
        {
            <MudStack Spacing="2">
                <MudText Typo="Typo.subtitle1"><strong>@_viewingOrderSet.Name</strong></MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_viewingOrderSet.Description</MudText>
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2">Included Orders:</MudText>
                <MudList T="OrderSetItem" Dense="true">
                    @foreach (var item in _viewingOrderSet.Items)
                    {
                        <MudListItem Icon="@GetOrderTypeIcon(item.Type)">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudChip T="string" Size="Size.Small" Color="@GetOrderTypeColor(item.Type)">@item.Type</MudChip>
                                <MudText Typo="Typo.body2">@item.Name</MudText>
                                @if (!string.IsNullOrEmpty(item.Details))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">- @item.Details</MudText>
                                }
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showOrderSetDialog = false)">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<NoteTemplate> _templates = new();
    private List<SmartPhrase> _smartPhrases = new();
    private List<OrderSet> _orderSets = new();
    
    private NoteTemplate? _editingTemplate;
    private OrderSet? _viewingOrderSet;
    private bool _showTemplateDialog;
    private bool _showViewDialog;
    private bool _showOrderSetDialog;
    private string _viewTitle = "";
    private string _viewContent = "";

    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new("Admin", "/admin", icon: Icons.Material.Filled.AdminPanelSettings),
        new("Templates & Order Sets", "/admin/templates", disabled: true)
    };

    protected override async Task OnInitializedAsync()
    {
        _templates = await ClinicalDataService.GetNoteTemplatesAsync();
        _smartPhrases = await ClinicalDataService.GetSmartPhrasesAsync();
        _orderSets = await ClinicalDataService.GetOrderSetsAsync();
    }

    private void OpenTemplateDialog() { _editingTemplate = new NoteTemplate { IsShared = true, IsActive = true }; _showTemplateDialog = true; }
    private void EditTemplate(NoteTemplate t) { _editingTemplate = new NoteTemplate { Id = t.Id, Name = t.Name, Category = t.Category, VisitType = t.VisitType, Content = t.Content, IsShared = t.IsShared }; _showTemplateDialog = true; }
    private void ViewTemplate(NoteTemplate t) { _viewTitle = t.Name; _viewContent = t.Content; _showViewDialog = true; }
    
    private void OpenPhraseDialog() { Snackbar.Add("Smart phrase editor opening...", Severity.Info); }
    private void OpenOrderSetDialog() { Snackbar.Add("Order set editor opening...", Severity.Info); }
    private void ViewOrderSet(OrderSet o) { _viewingOrderSet = o; _showOrderSetDialog = true; }

    private async Task SaveTemplate()
    {
        if (_editingTemplate == null) return;
        _editingTemplate.CreatedBy = "Dr. Sarah Smith";
        if (_editingTemplate.Id == 0)
            await ClinicalDataService.CreateNoteTemplateAsync(_editingTemplate);
        _templates = await ClinicalDataService.GetNoteTemplatesAsync();
        _showTemplateDialog = false;
        Snackbar.Add("Template saved", Severity.Success);
    }

    private string GetOrderTypeIcon(OrderType type) => type switch
    {
        OrderType.Lab => Icons.Material.Filled.Science,
        OrderType.Imaging => Icons.Material.Filled.Image,
        OrderType.Medication => Icons.Material.Filled.Medication,
        OrderType.Referral => Icons.Material.Filled.GroupAdd,
        _ => Icons.Material.Filled.Assignment
    };

    private Color GetOrderTypeColor(OrderType type) => type switch
    {
        OrderType.Lab => Color.Warning,
        OrderType.Imaging => Color.Info,
        OrderType.Medication => Color.Success,
        OrderType.Referral => Color.Secondary,
        _ => Color.Default
    };
}
