@page "/forgot-password"
@layout AuthLayout
@attribute [AllowAnonymous]
@inject UserManager<ApplicationUser> UserManager
@inject NotificationService Notifications
@inject NavigationManager Navigation

<PageTitle>Forgot Password - Zebrahoof EMR</PageTitle>

<MudCard Elevation="4" Class="pa-4" Style="width: 100%; max-width: 400px;">
    <MudCardHeader>
        <CardHeaderContent>
            <div class="d-flex flex-column align-center">
                <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
                <MudText Typo="Typo.h5">Forgot Password</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary text-center">
                    Enter your username and we'll send you a password reset link.
                </MudText>
            </div>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (_submitted)
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                If an account exists with that username, we've sent password reset instructions to the associated email address.
            </MudAlert>
            <MudButton Variant="Variant.Outlined" FullWidth="true" Href="/login">
                Back to Login
            </MudButton>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="forgot-password">
                <DataAnnotationsValidator />
                
                <MudTextField @bind-Value="_model.Username" 
                              Label="Username" 
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              Class="mb-4"
                              Required="true"
                              Disabled="_isLoading" />

                <MudButton ButtonType="ButtonType.Submit" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           FullWidth="true"
                           Disabled="_isLoading"
                           Class="mb-2">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Send Reset Link
                </MudButton>
                
                <MudButton Variant="Variant.Text" FullWidth="true" Href="/login">
                    Back to Login
                </MudButton>
            </EditForm>
        }
    </MudCardContent>
</MudCard>

@code {
    private ForgotPasswordModel _model = new();
    private bool _isLoading;
    private bool _submitted;

    private async Task HandleSubmit()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var user = await UserManager.FindByNameAsync(_model.Username);
            if (user != null && !string.IsNullOrEmpty(user.Email))
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(user);
                var resetUrl = Navigation.ToAbsoluteUri($"/reset-password?token={Uri.EscapeDataString(token)}&username={Uri.EscapeDataString(user.UserName ?? "")}").ToString();

                Notifications.ShowTemplatePreview("Password Reset", new Dictionary<string, string>
                {
                    ["To"] = user.Email,
                    ["Subject"] = "Reset Your Zebrahoof EMR Password",
                    ["Reset Link"] = resetUrl,
                    ["Expires"] = "24 hours"
                });
            }

            _submitted = true;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private class ForgotPasswordModel
    {
        public string Username { get; set; } = string.Empty;
    }
}
