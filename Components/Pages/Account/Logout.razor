@page "/logout"
@layout AuthLayout
@attribute [AllowAnonymous]
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation
@inject IAuditLogger AuditLogger

<PageTitle>Signing Out - Zebrahoof EMR</PageTitle>

<MudCard Elevation="4" Class="pa-4" Style="width: 100%; max-width: 400px;">
    <MudCardContent Class="d-flex flex-column align-center">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" Class="mb-4" />
        <MudText Typo="Typo.h6">Signing out...</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Please wait while we securely sign you out.</MudText>
    </MudCardContent>
</MudCard>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await AuditLogger.LogAsync("Logout", "Authentication", null, SignInManager.Context.User?.Identity?.Name);
                await SignInManager.SignOutAsync();
            }
            catch
            {
            }

            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }
}
