@page "/inbox"
@using Zebrahoof_EMR.Models
@inject MockClinicalDataService ClinicalDataService
@inject NavigationManager Navigation

<PageTitle>Inbox - Zebrahoof EMR</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudText Typo="Typo.h4">Inbox</MudText>
        @if (_unreadCount > 0)
        {
            <MudChip T="string" Color="Color.Error" Size="Size.Small">@_unreadCount unread</MudChip>
        }
    </MudStack>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Create"
               OnClick="OpenComposeDialog">
        Compose
    </MudButton>
</MudStack>

<MudGrid>
    <MudItem xs="12" md="5" lg="4">
        <MudCard Elevation="2" Style="height: calc(100vh - 200px); overflow: hidden;">
            <MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="0" Rounded="false" ApplyEffectsToContainer="true" 
                     PanelClass="pa-0" Style="height: 100%;">
                <MudTabPanel Text="All" BadgeData="@_allMessages.Count.ToString()" BadgeColor="Color.Primary">
                    @RenderMessageList(_allMessages)
                </MudTabPanel>
                <MudTabPanel Text="Messages" Icon="@Icons.Material.Filled.Email">
                    @RenderMessageList(_allMessages.Where(m => m.Category == MessageCategory.PatientMessage || m.Category == MessageCategory.TeamMessage).ToList())
                </MudTabPanel>
                <MudTabPanel Text="Results" Icon="@Icons.Material.Filled.Science">
                    @RenderMessageList(_allMessages.Where(m => m.Category == MessageCategory.LabResult || m.Category == MessageCategory.ImagingResult).ToList())
                </MudTabPanel>
                <MudTabPanel Text="Refills" Icon="@Icons.Material.Filled.Medication">
                    @RenderMessageList(_allMessages.Where(m => m.Category == MessageCategory.RefillRequest).ToList())
                </MudTabPanel>
                <MudTabPanel Text="Admin" Icon="@Icons.Material.Filled.AdminPanelSettings">
                    @RenderMessageList(_allMessages.Where(m => m.Category == MessageCategory.Administrative || m.Category == MessageCategory.ReferralResponse).ToList())
                </MudTabPanel>
            </MudTabs>
        </MudCard>
        
        <MudStack Row="true" Class="mt-2" Spacing="1">
            <MudChip T="string" Color="@(_filterUnread ? Color.Primary : Color.Default)" Variant="Variant.Outlined"
                     OnClick="@(() => ToggleFilter("unread"))">
                <MudIcon Icon="@Icons.Material.Filled.Markunread" Size="Size.Small" Class="mr-1" /> Unread
            </MudChip>
            <MudChip T="string" Color="@(_filterFlagged ? Color.Warning : Color.Default)" Variant="Variant.Outlined"
                     OnClick="@(() => ToggleFilter("flagged"))">
                <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small" Class="mr-1" /> Flagged
            </MudChip>
        </MudStack>
    </MudItem>
    
    <MudItem xs="12" md="7" lg="8">
        @if (_selectedMessage != null)
        {
            <MudCard Elevation="2" Style="height: calc(100vh - 200px); overflow: auto;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Spacing="1">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                <MudText Typo="Typo.h6">@_selectedMessage.Subject</MudText>
                                <MudStack Row="true" Spacing="1">
                                    @if (_selectedMessage.IsUrgent)
                                    {
                                        <MudChip T="string" Color="Color.Error" Size="Size.Small">Urgent</MudChip>
                                    }
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@GetCategoryName(_selectedMessage.Category)</MudChip>
                                </MudStack>
                            </MudStack>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                From: <strong>@_selectedMessage.FromName</strong> 
                                @if (!string.IsNullOrEmpty(_selectedMessage.FromRole))
                                {
                                    <text> (@_selectedMessage.FromRole)</text>
                                }
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">@_selectedMessage.SentAt.ToString("f")</MudText>
                            @if (_selectedMessage.PatientId.HasValue)
                            {
                                <MudLink Href="@($"/patients/{_selectedMessage.PatientId}")" Typo="Typo.body2">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                                    @_selectedMessage.PatientName
                                </MudLink>
                            }
                        </MudStack>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@(_selectedMessage.IsFlagged ? Icons.Material.Filled.Flag : Icons.Material.Outlined.Flag)"
                                       Color="@(_selectedMessage.IsFlagged ? Color.Warning : Color.Default)"
                                       OnClick="ToggleFlag" />
                        <MudIconButton Icon="@Icons.Material.Filled.Archive" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudDivider />
                <MudCardContent>
                    <MudText Typo="Typo.body1" Style="white-space: pre-wrap;">@_selectedMessage.Body</MudText>
                </MudCardContent>
                <MudDivider />
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Reply"
                               OnClick="OpenReplyDialog">
                        Reply
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Forward">
                        Forward
                    </MudButton>
                    @if (_selectedMessage.PatientId.HasValue)
                    {
                        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.OpenInNew"
                                   Href="@($"/patients/{_selectedMessage.PatientId}")">
                            Open Chart
                        </MudButton>
                    }
                </MudCardActions>
            </MudCard>
        }
        else
        {
            <MudCard Elevation="2" Style="height: calc(100vh - 200px);">
                <MudCardContent Class="d-flex align-center justify-center" Style="height: 100%;">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary">Select a message to view</MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        }
    </MudItem>
</MudGrid>

<MudDialog @bind-Visible="_showReplyDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">Reply to: @_selectedMessage?.Subject</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string" @bind-Value="_replyBody" Label="Message" Lines="6" Variant="Variant.Outlined" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showReplyDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SendReply">Send</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showComposeDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">New Message</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField T="string" @bind-Value="_composeRecipient" Label="To" Variant="Variant.Outlined" />
            <MudTextField T="string" @bind-Value="_composeSubject" Label="Subject" Variant="Variant.Outlined" />
            <MudTextField T="string" @bind-Value="_composeBody" Label="Message" Lines="6" Variant="Variant.Outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showComposeDialog = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SendNewMessage">Send</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<InboxMessage> _allMessages = new();
    private InboxMessage? _selectedMessage;
    private int _activeTab;
    private int _unreadCount;
    private bool _filterUnread;
    private bool _filterFlagged;
    
    private bool _showReplyDialog;
    private string _replyBody = "";
    
    private bool _showComposeDialog;
    private string _composeRecipient = "";
    private string _composeSubject = "";
    private string _composeBody = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadMessages();
    }

    private async Task LoadMessages()
    {
        _allMessages = await ClinicalDataService.GetInboxMessagesAsync(
            unreadOnly: _filterUnread ? true : null,
            flaggedOnly: _filterFlagged ? true : null);
        _unreadCount = await ClinicalDataService.GetUnreadMessageCountAsync();
    }

    private async Task SelectMessage(InboxMessage message)
    {
        _selectedMessage = message;
        if (!message.IsRead)
        {
            await ClinicalDataService.MarkMessageAsReadAsync(message.Id);
            message.IsRead = true;
            _unreadCount = await ClinicalDataService.GetUnreadMessageCountAsync();
        }
    }

    private async Task ToggleFilter(string filter)
    {
        if (filter == "unread") _filterUnread = !_filterUnread;
        if (filter == "flagged") _filterFlagged = !_filterFlagged;
        await LoadMessages();
    }

    private async Task ToggleFlag()
    {
        if (_selectedMessage == null) return;
        await ClinicalDataService.ToggleMessageFlagAsync(_selectedMessage.Id);
        _selectedMessage.IsFlagged = !_selectedMessage.IsFlagged;
    }

    private void OpenReplyDialog() => _showReplyDialog = true;
    private void OpenComposeDialog() => _showComposeDialog = true;

    private async Task SendReply()
    {
        if (_selectedMessage == null) return;
        
        var reply = new InboxMessage
        {
            Subject = $"RE: {_selectedMessage.Subject}",
            Body = _replyBody,
            FromName = "Dr. Sarah Smith",
            ToName = _selectedMessage.FromName,
            PatientId = _selectedMessage.PatientId,
            PatientName = _selectedMessage.PatientName,
            Category = _selectedMessage.Category,
            ParentMessageId = _selectedMessage.Id
        };
        
        await ClinicalDataService.SendMessageAsync(reply);
        _showReplyDialog = false;
        _replyBody = "";
        await LoadMessages();
    }

    private async Task SendNewMessage()
    {
        var message = new InboxMessage
        {
            Subject = _composeSubject,
            Body = _composeBody,
            FromName = "Dr. Sarah Smith",
            ToName = _composeRecipient,
            Category = MessageCategory.TeamMessage
        };
        
        await ClinicalDataService.SendMessageAsync(message);
        _showComposeDialog = false;
        _composeRecipient = "";
        _composeSubject = "";
        _composeBody = "";
        await LoadMessages();
    }

    private string GetCategoryName(MessageCategory category) => category switch
    {
        MessageCategory.PatientMessage => "Patient",
        MessageCategory.LabResult => "Lab Result",
        MessageCategory.ImagingResult => "Imaging",
        MessageCategory.RefillRequest => "Refill",
        MessageCategory.ReferralResponse => "Referral",
        MessageCategory.Administrative => "Admin",
        MessageCategory.ClinicalQuestion => "Clinical",
        MessageCategory.TeamMessage => "Team",
        _ => category.ToString()
    };
}

@code {
    private RenderFragment RenderMessageList(List<InboxMessage> messages) => __builder =>
    {
        <MudList T="InboxMessage" Dense="true" Class="pa-0" Style="height: calc(100vh - 300px); overflow-y: auto;">
            @if (messages.Count == 0)
            {
                <MudListItem>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">No messages</MudText>
                </MudListItem>
            }
            else
            {
                @foreach (var msg in messages)
                {
                    <MudListItem OnClick="@(() => SelectMessage(msg))"
                                 Class="@(_selectedMessage?.Id == msg.Id ? "mud-primary-lighten" : "")"
                                 Style="@(!msg.IsRead ? "font-weight: bold; background-color: var(--mud-palette-background-grey);" : "")">
                        <MudStack Spacing="0" Class="py-1">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.body2" Style="@(!msg.IsRead ? "font-weight: 600;" : "")">
                                    @(msg.Subject.Length > 35 ? msg.Subject[..35] + "..." : msg.Subject)
                                </MudText>
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    @if (msg.IsUrgent)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.PriorityHigh" Size="Size.Small" Color="Color.Error" />
                                    }
                                    @if (msg.IsFlagged)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small" Color="Color.Warning" />
                                    }
                                </MudStack>
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@msg.FromName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">@msg.SentAt.ToString("MM/dd HH:mm")</MudText>
                        </MudStack>
                    </MudListItem>
                }
            }
        </MudList>
    };
}
