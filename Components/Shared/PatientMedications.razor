@inject MockClinicalDataService ClinicalDataService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IDisposable

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4">
    @* Medication List Tab - Active Long-Term Medications *@
    <MudTabPanel Text="Medication List" Icon="@Icons.Material.Filled.List">
        <MudCard Elevation="0">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Current Medications</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Active long-term medications only</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PlaylistAdd" OnClick="OpenAddToListDialog" Class="mr-2">
                        Add to List
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenPrescribeDialog">
                        Prescribe New
                    </MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-0">
                <MudTable Items="@MedicationList" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Medication</MudTh>
                        <MudTh>Dose</MudTh>
                        <MudTh>Route</MudTh>
                        <MudTh>Frequency</MudTh>
                        <MudTh>Refills</MudTh>
                        <MudTh>Pharmacy</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Medication">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                @context.Name
                                @if (context.IsHighRisk)
                                {
                                    <MudTooltip Text="High-risk medication">
                                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" />
                                    </MudTooltip>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Dose">@context.Dose</MudTd>
                        <MudTd DataLabel="Route">@context.Route</MudTd>
                        <MudTd DataLabel="Frequency">@context.Frequency</MudTd>
                        <MudTd DataLabel="Refills">@(context.RefillsRemaining ?? 0)</MudTd>
                        <MudTd DataLabel="Pharmacy">@context.Pharmacy</MudTd>
                        <MudTd>
                            <MudTooltip Text="Edit Medication">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Secondary" OnClick="@(() => OpenEditMedicationDialog(context))" />
                            </MudTooltip>
                            <MudTooltip Text="Order Refill">
                                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OrderRefill(context))" />
                            </MudTooltip>
                            <MudTooltip Text="View History">
                                <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" OnClick="@(() => ViewMedicationHistory(context))" />
                            </MudTooltip>
                            <MudTooltip Text="Discontinue">
                                <MudIconButton Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Error" OnClick="@(() => DiscontinueMedication(context))" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4">No active medications on the medication list</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudTabPanel>

    @* Prescription History Tab *@
    <MudTabPanel Text="Prescription History" Icon="@Icons.Material.Filled.History">
        <MudCard Elevation="0">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Prescription History</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">All prescriptions including short-term medications</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent Class="pa-0">
                <MudTable Items="@_prescriptions" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Medication</MudTh>
                        <MudTh>Dose</MudTh>
                        <MudTh>Frequency</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Prescriber</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Date">@context.PrescribedDate.ToString("MM/dd/yyyy")</MudTd>
                        <MudTd DataLabel="Medication">
                            @context.MedicationName
                            @if (context.IsRefill)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-2">Refill</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Dose">@context.Dose</MudTd>
                        <MudTd DataLabel="Frequency">@context.Frequency</MudTd>
                        <MudTd DataLabel="Type">
                            <MudChip T="string" Size="Size.Small" Color="@(context.Type == PrescriptionType.LongTerm ? Color.Primary : Color.Secondary)">
                                @(context.Type == PrescriptionType.LongTerm ? "Long-term" : "Short-term")
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Color="@GetPrescriptionStatusColor(context.Status)">@context.Status</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Prescriber">@context.Prescriber</MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4">No prescription history found</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudTabPanel>

    @* All Medications Tab (including discontinued) *@
    <MudTabPanel Text="All Medications" Icon="@Icons.Material.Filled.Medication">
        <MudCard Elevation="0">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">All Medications</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Including discontinued medications</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudToggleGroup T="string" @bind-Value="_statusFilter" Style="height: 36px;">
                        <MudToggleItem Value="@("active")">Active</MudToggleItem>
                        <MudToggleItem Value="@("discontinued")">Discontinued</MudToggleItem>
                        <MudToggleItem Value="@("all")">All</MudToggleItem>
                    </MudToggleGroup>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-0">
                <MudTable Items="@FilteredMedications" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Medication</MudTh>
                        <MudTh>Dose</MudTh>
                        <MudTh>Route</MudTh>
                        <MudTh>Frequency</MudTh>
                        <MudTh>Start Date</MudTh>
                        <MudTh>End Date</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Type</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Medication">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                @context.Name
                                @if (context.IsHighRisk)
                                {
                                    <MudTooltip Text="High-risk medication">
                                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" />
                                    </MudTooltip>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Dose">@context.Dose</MudTd>
                        <MudTd DataLabel="Route">@context.Route</MudTd>
                        <MudTd DataLabel="Frequency">@context.Frequency</MudTd>
                        <MudTd DataLabel="Start">@context.StartDate.ToString("MM/dd/yyyy")</MudTd>
                        <MudTd DataLabel="End">@(context.EndDate?.ToString("MM/dd/yyyy") ?? "—")</MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Type">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@(context.IsLongTerm ? Color.Primary : Color.Secondary)">
                                @(context.IsLongTerm ? "Long-term" : "Short-term")
                            </MudChip>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4">No medications found</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudTabPanel>
</MudTabs>

@* Prescribe Medication Dialog *@
<MudDialog @bind-Visible="_showPrescribeDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" /> Prescribe Medication
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_prescribeForm" @bind-IsValid="_prescribeFormValid">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudAutocomplete T="MedicationCatalog" Label="Medication Name" Value="_newPrescription.SelectedMedication" ValueChanged="OnMedicationSelected" Required="true" RequiredError="Medication is required" SearchFunc="@SearchMedications" ToStringFunc="@GetMedicationName" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_newPrescription.Dose" Label="Dose" Required="true" RequiredError="Dose is required" Placeholder="e.g., 10mg, 500mg" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="_newPrescription.Route" Label="Route" Required="true" RequiredError="Route is required">
                        <MudSelectItem Value="@("Oral")">Oral</MudSelectItem>
                        <MudSelectItem Value="@("Subcutaneous")">Subcutaneous</MudSelectItem>
                        <MudSelectItem Value="@("Intramuscular")">Intramuscular</MudSelectItem>
                        <MudSelectItem Value="@("Intravenous")">Intravenous</MudSelectItem>
                        <MudSelectItem Value="@("Topical")">Topical</MudSelectItem>
                        <MudSelectItem Value="@("Inhalation")">Inhalation</MudSelectItem>
                        <MudSelectItem Value="@("Ophthalmic")">Ophthalmic</MudSelectItem>
                        <MudSelectItem Value="@("Otic")">Otic</MudSelectItem>
                        <MudSelectItem Value="@("Rectal")">Rectal</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_newPrescription.Frequency" Label="Frequency" Required="true" RequiredError="Frequency is required" Placeholder="e.g., Once daily, Twice daily" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="_newPrescription.DaysSupply" Label="Days Supply" Min="1" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="_newPrescription.Quantity" Label="Quantity" Min="1" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="_newPrescription.Refills" Label="Refills" Min="0" Max="12" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_newPrescription.Instructions" Label="Instructions" Lines="2" Placeholder="Special instructions for the patient" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_newPrescription.Pharmacy" Label="Pharmacy" Placeholder="e.g., CVS Pharmacy" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_newPrescription.Prescriber" Label="Prescriber" />
                </MudItem>
                <MudItem xs="12">
                    <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center">
                        <MudSwitch @bind-Value="_newPrescription.IsLongTerm" Color="Color.Primary" Label="Long-term medication" />
                        <MudSwitch @bind-Value="_newPrescription.IsHighRisk" Color="Color.Error" Label="High-risk medication" />
                    </MudStack>
                    @if (_newPrescription.IsLongTerm)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                            Long-term medications will be added to the patient's medication list.
                        </MudAlert>
                    }
                    @if (_duplicateWarning)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                            This medication is already on the patient's medication list. A new prescription will be created but the medication list will not be duplicated.
                        </MudAlert>
                    }
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="ClosePrescribeDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitPrescription" Disabled="@(!_prescribeFormValid)">
            Prescribe
        </MudButton>
    </DialogActions>
</MudDialog>

@* Refill Dialog *@
<MudDialog @bind-Visible="_showRefillDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Refresh" Class="mr-2" /> Order Refill
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_selectedMedication != null)
        {
            <MudStack Spacing="2">
                <MudText Typo="Typo.body1"><strong>@_selectedMedication.Name</strong> @_selectedMedication.Dose</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_selectedMedication.Frequency • @_selectedMedication.Route</MudText>
                <MudDivider Class="my-2" />
                <MudNumericField @bind-Value="_refillDaysSupply" Label="Days Supply" Min="1" />
                <MudTextField @bind-Value="_refillPharmacy" Label="Pharmacy" />
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseRefillDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitRefill">
            Order Refill
        </MudButton>
    </DialogActions>
</MudDialog>

@* Discontinue Dialog *@
<MudDialog @bind-Visible="_showDiscontinueDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Cancel" Class="mr-2" Color="Color.Error" /> Discontinue Medication
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_selectedMedication != null)
        {
            <MudStack Spacing="2">
                <MudAlert Severity="Severity.Warning" Dense="true">
                    Are you sure you want to discontinue this medication?
                </MudAlert>
                <MudText Typo="Typo.body1"><strong>@_selectedMedication.Name</strong> @_selectedMedication.Dose</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@_selectedMedication.Frequency • @_selectedMedication.Route</MudText>
                <MudDivider Class="my-2" />
                <MudTextField @bind-Value="_discontinueReason" Label="Reason for Discontinuation" Lines="2" />
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDiscontinueDialog">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="SubmitDiscontinue">
            Discontinue
        </MudButton>
    </DialogActions>
</MudDialog>

@* Medication History Dialog *@
<MudDialog @bind-Visible="_showHistoryDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.History" Class="mr-2" /> Medication History
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_selectedMedication != null)
        {
            <MudStack Spacing="2">
                <MudText Typo="Typo.body1"><strong>@_selectedMedication.Name</strong> @_selectedMedication.Dose</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Started: @_selectedMedication.StartDate.ToString("MM/dd/yyyy") • Prescriber: @_selectedMedication.Prescriber</MudText>
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2">Prescription History</MudText>
                <MudTable Items="@_medicationPrescriptions" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Days Supply</MudTh>
                        <MudTh>Quantity</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Prescriber</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.PrescribedDate.ToString("MM/dd/yyyy")</MudTd>
                        <MudTd>
                            @if (context.IsRefill)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">Refill</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary">New</MudChip>
                            }
                        </MudTd>
                        <MudTd>@context.DaysSupply days</MudTd>
                        <MudTd>@context.Quantity</MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@GetPrescriptionStatusColor(context.Status)">@context.Status</MudChip>
                        </MudTd>
                        <MudTd>@context.Prescriber</MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4">No prescription history found</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseHistoryDialog">Close</MudButton>
    </DialogActions>
</MudDialog>

@* Add to List Dialog (without prescription) *@
<MudDialog @bind-Visible="_showAddToListDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PlaylistAdd" Class="mr-2" /> Add Medication to List
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            Add a medication the patient is taking without creating a prescription (e.g., medication from another provider).
        </MudAlert>
        <MudForm @ref="_addToListForm" @bind-IsValid="_addToListFormValid">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_addToListModel.MedicationName" Label="Medication Name" Required="true" RequiredError="Medication name is required" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_addToListModel.Dose" Label="Dose" Required="true" RequiredError="Dose is required" Placeholder="e.g., 10mg, 500mg" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="_addToListModel.Route" Label="Route" Required="true" RequiredError="Route is required">
                        <MudSelectItem Value="@("Oral")">Oral</MudSelectItem>
                        <MudSelectItem Value="@("Subcutaneous")">Subcutaneous</MudSelectItem>
                        <MudSelectItem Value="@("Intramuscular")">Intramuscular</MudSelectItem>
                        <MudSelectItem Value="@("Intravenous")">Intravenous</MudSelectItem>
                        <MudSelectItem Value="@("Topical")">Topical</MudSelectItem>
                        <MudSelectItem Value="@("Inhalation")">Inhalation</MudSelectItem>
                        <MudSelectItem Value="@("Ophthalmic")">Ophthalmic</MudSelectItem>
                        <MudSelectItem Value="@("Otic")">Otic</MudSelectItem>
                        <MudSelectItem Value="@("Rectal")">Rectal</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_addToListModel.Frequency" Label="Frequency" Required="true" RequiredError="Frequency is required" Placeholder="e.g., Once daily, Twice daily" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_addToListModel.Prescriber" Label="Prescriber" Placeholder="e.g., Dr. External Provider" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_addToListModel.Pharmacy" Label="Pharmacy" Placeholder="e.g., CVS Pharmacy" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_addToListModel.Instructions" Label="Instructions" Lines="2" Placeholder="Special instructions for the patient" />
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_addToListModel.IsHighRisk" Color="Color.Error" Label="High-risk medication" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseAddToListDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitAddToList" Disabled="@(!_addToListFormValid)">
            Add to List
        </MudButton>
    </DialogActions>
</MudDialog>

@* Edit Medication Dialog *@
<MudDialog @bind-Visible="_showEditMedicationDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" /> Edit Medication
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_editMedicationForm" @bind-IsValid="_editMedicationFormValid">
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1"><strong>@_editMedicationModel.MedicationName</strong></MudText>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_editMedicationModel.Dose" Label="Dose" Required="true" RequiredError="Dose is required" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="_editMedicationModel.Route" Label="Route" Required="true" RequiredError="Route is required">
                        <MudSelectItem Value="@("Oral")">Oral</MudSelectItem>
                        <MudSelectItem Value="@("Subcutaneous")">Subcutaneous</MudSelectItem>
                        <MudSelectItem Value="@("Intramuscular")">Intramuscular</MudSelectItem>
                        <MudSelectItem Value="@("Intravenous")">Intravenous</MudSelectItem>
                        <MudSelectItem Value="@("Topical")">Topical</MudSelectItem>
                        <MudSelectItem Value="@("Inhalation")">Inhalation</MudSelectItem>
                        <MudSelectItem Value="@("Ophthalmic")">Ophthalmic</MudSelectItem>
                        <MudSelectItem Value="@("Otic")">Otic</MudSelectItem>
                        <MudSelectItem Value="@("Rectal")">Rectal</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_editMedicationModel.Frequency" Label="Frequency" Required="true" RequiredError="Frequency is required" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_editMedicationModel.RefillsRemaining" Label="Refills Remaining" Min="0" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_editMedicationModel.DaysSupply" Label="Days Supply" Min="1" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_editMedicationModel.Pharmacy" Label="Pharmacy" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_editMedicationModel.Instructions" Label="Instructions" Lines="2" />
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_editMedicationModel.IsHighRisk" Color="Color.Error" Label="High-risk medication" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseEditMedicationDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitEditMedication" Disabled="@(!_editMedicationFormValid)">
            Save Changes
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter, EditorRequired]
    public int PatientId { get; set; }

    private List<Medication> _medications = new();
    private List<Prescription> _prescriptions = new();
    private List<Prescription> _medicationPrescriptions = new();
    private List<MedicationCatalog> _medicationCatalog = new();
    private string _statusFilter = "active";

    // Medication list (active long-term only)
    private IEnumerable<Medication> MedicationList => _medications.Where(m => m.IsLongTerm && m.Status == MedicationStatus.Active);

    private IEnumerable<Medication> FilteredMedications => _statusFilter switch
    {
        "active" => _medications.Where(m => m.Status == MedicationStatus.Active),
        "discontinued" => _medications.Where(m => m.Status == MedicationStatus.Discontinued),
        _ => _medications
    };

    // Dialog state
