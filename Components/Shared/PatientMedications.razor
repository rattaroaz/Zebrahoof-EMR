    private bool _showRefillDialog;
    private bool _showDiscontinueDialog;
    private bool _showHistoryDialog;
    private bool _showAddToListDialog;
    private bool _showEditMedicationDialog;
    private MudForm? _prescribeForm;
    private MudForm? _addToListForm;
    private MudForm? _editMedicationForm;
