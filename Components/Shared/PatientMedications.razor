    private async Task SubmitEditMedication()
    {
        if (_editMedicationForm != null)
        {
            await _editMedicationForm.Validate();
            if (!_editMedicationFormValid) return;
        }

        await ClinicalDataService.UpdateMedicationAsync(
            _editMedicationModel.MedicationId,
            _editMedicationModel.Dose,
            _editMedicationModel.Route,
            _editMedicationModel.Frequency,
            null, // prescriber - don't update
            _editMedicationModel.Pharmacy,
            _editMedicationModel.Instructions,
            _editMedicationModel.RefillsRemaining,
            _editMedicationModel.DaysSupply,
            _editMedicationModel.IsHighRisk
        );

        await LoadData();
        CloseEditMedicationDialog();
        Snackbar.Add($"{_editMedicationModel.MedicationName} updated successfully", Severity.Success);
    }

    public Task<IEnumerable<MedicationCatalog>> SearchMedications(string value, CancellationToken token = default)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(_medicationCatalog.AsEnumerable());
        
        var filtered = _medicationCatalog.Where(m => 
            m.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            m.BrandNames.Any(b => b.Contains(value, StringComparison.OrdinalIgnoreCase)));
        return Task.FromResult(filtered);
    }

    public string GetMedicationName(MedicationCatalog item)
    {
        if (item == null) return string.Empty;
        if (item.BrandNames.Count > 0)
            return $"{item.Name} ({string.Join(", ", item.BrandNames)})";
        return item.Name;
    }

    private void OnMedicationSelected(MedicationCatalog? medication)
    {
        if (medication != null)
        {
            _newPrescription.MedicationName = medication.Name;
            _newPrescription.Dose = medication.CommonDoses.FirstOrDefault() ?? string.Empty;
            _newPrescription.Route = medication.CommonRoutes.FirstOrDefault() ?? "Oral";
            _newPrescription.Frequency = medication.CommonFrequencies.FirstOrDefault() ?? string.Empty;
            _newPrescription.IsHighRisk = medication.IsHighRisk;
        }
    }

    private Color GetStatusColor(MedicationStatus status) => status switch
    {
        MedicationStatus.Active => Color.Success,
        MedicationStatus.Discontinued => Color.Error,
        MedicationStatus.OnHold => Color.Warning,
        MedicationStatus.Completed => Color.Info,
        _ => Color.Default
    };

    private Color GetPrescriptionStatusColor(PrescriptionStatus status) => status switch
    {
        PrescriptionStatus.Active => Color.Primary,
        PrescriptionStatus.Filled => Color.Success,
        PrescriptionStatus.Cancelled => Color.Error,
        PrescriptionStatus.Expired => Color.Warning,
        _ => Color.Default
    };

