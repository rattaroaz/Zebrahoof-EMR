    protected override async Task OnParametersSetAsync()
    {
        ClinicalDataService.PatientDataChanged -= OnPatientDataChanged;
        ClinicalDataService.PatientDataChanged += OnPatientDataChanged;
        await LoadData();
    }

    private async Task LoadData()
    {
        _medications = await ClinicalDataService.GetMedicationsByPatientAsync(PatientId);
        _prescriptions = await ClinicalDataService.GetPrescriptionsByPatientAsync(PatientId);
        _medicationCatalog = await ClinicalDataService.GetMedicationCatalogAsync();
    }

    private async void OnPatientDataChanged(int patientId)
    {
        if (patientId != PatientId) return;
        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ClinicalDataService.PatientDataChanged -= OnPatientDataChanged;
    }

    private void OpenPrescribeDialog()
    {
        _newPrescription = new PrescriptionFormModel
        {
            Prescriber = "Dr. Sarah Smith",
            Route = "Oral",
            IsLongTerm = true
        };
        _duplicateWarning = false;
        _showPrescribeDialog = true;
    }

    private void ClosePrescribeDialog()
    {
        _showPrescribeDialog = false;
        _newPrescription = new();
    }

    private async Task SubmitPrescription()
    {
        if (_prescribeForm != null)
        {
            await _prescribeForm.Validate();
            if (!_prescribeFormValid) return;
        }

        // Check for duplicates if long-term
        if (_newPrescription.IsLongTerm)
        {
            var isDuplicate = await ClinicalDataService.IsMedicationOnListAsync(PatientId, _newPrescription.MedicationName);
            if (isDuplicate)
            {
                _duplicateWarning = true;
                // Still allow prescription, just warn - medication list won't be duplicated
            }
        }

        await ClinicalDataService.PrescribeMedicationAsync(
            PatientId,
            _newPrescription.MedicationName,
            _newPrescription.Dose,
            _newPrescription.Route,
            _newPrescription.Frequency,
            _newPrescription.IsLongTerm,
            _newPrescription.DaysSupply,
            _newPrescription.Quantity,
            _newPrescription.Refills,
            _newPrescription.Instructions,
            _newPrescription.Prescriber,
            _newPrescription.Pharmacy,
            _newPrescription.IsHighRisk
        );

        await LoadData();
        ClosePrescribeDialog();
        Snackbar.Add("Prescription created successfully", Severity.Success);
    }

    private void OrderRefill(Medication medication)
    {
        _selectedMedication = medication;
        _refillDaysSupply = medication.DaysSupply ?? 30;
        _refillPharmacy = medication.Pharmacy ?? string.Empty;
        _showRefillDialog = true;
    }

    private void CloseRefillDialog()
    {
        _showRefillDialog = false;
        _selectedMedication = null;
    }

    private async Task SubmitRefill()
    {
        if (_selectedMedication == null) return;

        var medName = _selectedMedication.Name;
        
        await ClinicalDataService.OrderRefillAsync(
            PatientId,
            _selectedMedication.Id,
            "Dr. Sarah Smith",
            _refillDaysSupply
        );

        await LoadData();
        CloseRefillDialog();
        Snackbar.Add($"Refill ordered for {medName}", Severity.Success);
    }

    private void DiscontinueMedication(Medication medication)
    {
        _selectedMedication = medication;
        _discontinueReason = string.Empty;
        _showDiscontinueDialog = true;
    }

    private void CloseDiscontinueDialog()
    {
        _showDiscontinueDialog = false;
        _selectedMedication = null;
    }

    private async Task SubmitDiscontinue()
    {
        if (_selectedMedication == null) return;

        await ClinicalDataService.DiscontinueMedicationAsync(_selectedMedication.Id, _discontinueReason);

        await LoadData();
        CloseDiscontinueDialog();
        Snackbar.Add($"{_selectedMedication.Name} has been discontinued", Severity.Info);
    }

    private async Task ViewMedicationHistory(Medication medication)
    {
        _selectedMedication = medication;
        _medicationPrescriptions = await ClinicalDataService.GetPrescriptionsByMedicationAsync(medication.Id);
        _showHistoryDialog = true;
    }

    private void CloseHistoryDialog()
    {
        _showHistoryDialog = false;
