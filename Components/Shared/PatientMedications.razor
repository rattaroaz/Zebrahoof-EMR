        _medicationPrescriptions = new();
    }

    // Add to List (without prescription) methods
    private void OpenAddToListDialog()
    {
        _addToListModel = new AddToListFormModel
        {
            Route = "Oral"
        };
        _showAddToListDialog = true;
    }

    private void CloseAddToListDialog()
    {
        _showAddToListDialog = false;
        _addToListModel = new();
    }

    private async Task SubmitAddToList()
    {
        if (_addToListForm != null)
        {
            await _addToListForm.Validate();
            if (!_addToListFormValid) return;
        }

        // Check for duplicates
        var isDuplicate = await ClinicalDataService.IsMedicationOnListAsync(PatientId, _addToListModel.MedicationName);
        if (isDuplicate)
        {
            Snackbar.Add("This medication is already on the patient's medication list", Severity.Warning);
            return;
        }

        await ClinicalDataService.AddMedicationToListAsync(
            PatientId,
            _addToListModel.MedicationName,
            _addToListModel.Dose,
            _addToListModel.Route,
            _addToListModel.Frequency,
            _addToListModel.Prescriber,
            _addToListModel.Pharmacy,
            _addToListModel.Instructions,
            _addToListModel.IsHighRisk
        );

        await LoadData();
        CloseAddToListDialog();
        Snackbar.Add($"{_addToListModel.MedicationName} added to medication list", Severity.Success);
    }

