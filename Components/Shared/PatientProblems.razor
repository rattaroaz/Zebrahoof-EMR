@inject MockClinicalDataService ClinicalDataService
@implements IDisposable

<MudCard Elevation="2">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Problem List</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudToggleGroup T="string" @bind-Value="_statusFilter" Style="height: 36px;">
                <MudToggleItem Value="@("all")">All</MudToggleItem>
                <MudToggleItem Value="@("active")">Active</MudToggleItem>
                <MudToggleItem Value="@("resolved")">Resolved</MudToggleItem>
            </MudToggleGroup>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="ml-3">
                Add Problem
            </MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent Class="pa-0">
        <MudTable Items="@FilteredProblems" Hover="true" Dense="true">
            <HeaderContent>
                <MudTh>Problem</MudTh>
                <MudTh>ICD Code</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Onset</MudTh>
                <MudTh>Severity</MudTh>
                <MudTh>Notes</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Problem">@context.Name</MudTd>
                <MudTd DataLabel="ICD">@context.IcdCode</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                </MudTd>
                <MudTd DataLabel="Onset">@context.OnsetDate.ToString("MM/dd/yyyy")</MudTd>
                <MudTd DataLabel="Severity">@(context.Severity ?? "—")</MudTd>
                <MudTd DataLabel="Notes">@(context.Notes ?? "—")</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                    @if (context.Status == ProblemStatus.Active)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" title="Mark Resolved" />
                    }
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4">No problems found</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public int PatientId { get; set; }

    private List<Problem> _problems = new();
    private string _statusFilter = "active";

    private IEnumerable<Problem> FilteredProblems => _statusFilter switch
    {
        "active" => _problems.Where(p => p.Status == ProblemStatus.Active),
        "resolved" => _problems.Where(p => p.Status == ProblemStatus.Resolved),
        _ => _problems
    };

    protected override async Task OnParametersSetAsync()
    {
        ClinicalDataService.PatientDataChanged -= OnPatientDataChanged;
        ClinicalDataService.PatientDataChanged += OnPatientDataChanged;
        _problems = await ClinicalDataService.GetProblemsByPatientAsync(PatientId);
    }

    private async void OnPatientDataChanged(int patientId)
    {
        if (patientId != PatientId) return;
        _problems = await ClinicalDataService.GetProblemsByPatientAsync(PatientId);
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ClinicalDataService.PatientDataChanged -= OnPatientDataChanged;
    }

    private Color GetStatusColor(ProblemStatus status) => status switch
    {
        ProblemStatus.Active => Color.Warning,
        ProblemStatus.Resolved => Color.Success,
        ProblemStatus.Inactive => Color.Default,
        _ => Color.Default
    };
}
