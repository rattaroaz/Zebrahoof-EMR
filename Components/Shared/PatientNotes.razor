@inject MockClinicalDataService ClinicalDataService
@inject AuthStateService AuthState
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>Clinical Notes - Zebrahoof EMR</PageTitle>

<MudStack Spacing="4">
    <!-- Header with View Toggle -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.h5">Clinical Notes</MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AccountTree" OnClick="@NavigateToTreeView">
                Tree View
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@OpenNewNoteDialog">
                New Note
            </MudButton>
        </MudStack>
    </MudStack>

    <!-- Notes List -->
    <MudCard Elevation="2">
        <MudCardContent>
            @if (_notes == null || _notes.Count == 0)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.NoteAdd" Size="Size.Large" Class="mud-text-secondary" />
                    <MudText Typo="Typo.h6" Class="mud-text-secondary">No clinical notes found</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary text-center">
                        Click "New Note" to create the first clinical note for this patient.
                    </MudText>
                    <MudButton Variant="Variant.Outlined" OnClick="@OpenNewNoteDialog" Class="mt-2">
                        Create First Note
                    </MudButton>
                </MudStack>
            }
            else
            {
                <MudStack Spacing="3">
                    @foreach (var note in _notes.OrderByDescending(n => n.CreatedAt))
                    {
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudStack Spacing="2">
                                <!-- Note Header -->
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudChip T="string" Size="Size.Small" Color="@GetNoteStatusColor(note.Status)">
                                            @note.Status
                                        </MudChip>
                                        <MudText Typo="Typo.h6">@(note.ChiefComplaint ?? "Clinical Note")</MudText>
                                    </MudStack>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        @if (note.Status == NoteStatus.InProgress)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" 
                                                          OnClick="@(() => EditNote(note))" title="Edit Note" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" 
                                                          OnClick="@(() => DeleteNote(note))" title="Delete Note" />
                                        }
                                        @if (note.Status == NoteStatus.InProgress && CanSignNote())
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.HowToReg" Size="Size.Small" 
                                                          Color="Color.Primary"
                                                          OnClick="@(() => SignNote(note))" title="Sign Note" />
                                        }
                                    </MudStack>
                                </MudStack>

                                <!-- Note Metadata -->
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        By @note.AuthorName on @note.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                    </MudText>
                                    @if (note.SignedAt.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Success">
                                            ✓ Signed on @note.SignedAt?.ToString("MMM dd, yyyy HH:mm")
                                        </MudText>
                                    }
                                </MudStack>

                                <!-- Chief Complaint -->
                                @if (!string.IsNullOrEmpty(note.ChiefComplaint))
                                {
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                                        Chief Complaint: @note.ChiefComplaint
                                    </MudText>
                                }

                                <!-- HPI Preview -->
                                @if (!string.IsNullOrEmpty(note.HistoryOfPresentIllness))
                                {
                                    <MudText Typo="Typo.body2">
                                        <strong>HPI:</strong> @(note.HistoryOfPresentIllness.Length > 200 ? note.HistoryOfPresentIllness.Substring(0, 200) + "..." : note.HistoryOfPresentIllness)
                                    </MudText>
                                }

                                <!-- Assessment and Plan Preview -->
                                @if (!string.IsNullOrEmpty(note.Assessment) || !string.IsNullOrEmpty(note.Plan))
                                {
                                    <MudText Typo="Typo.body2">
                                        @if (!string.IsNullOrEmpty(note.Assessment))
                                        {
                                            <strong>Assessment:</strong> @(note.Assessment.Length > 100 ? note.Assessment.Substring(0, 100) + "..." : note.Assessment)
                                        }
                                        @if (!string.IsNullOrEmpty(note.Plan))
                                        {
                                            <br />
                                            <strong>Plan:</strong> @(note.Plan.Length > 100 ? note.Plan.Substring(0, 100) + "..." : note.Plan)
                                        }
                                    </MudText>
                                }

                                <!-- View Full Note Button -->
                                <MudButton Variant="Variant.Text" Size="Size.Small" @onclick="@(() => ViewNote(note))">
                                    View Full Note
                                </MudButton>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }
        </MudCardContent>
    </MudCard>
</MudStack>

@code {
    [Parameter]
    public int PatientId { get; set; }

    private List<ClinicalNote>? _notes;

    protected override async Task OnInitializedAsync()
    {
        await LoadNotes();
    }

    private async Task LoadNotes()
    {
        _notes = await ClinicalDataService.GetPatientNotesAsync(PatientId);
    }

    private void NavigateToTreeView()
    {
        Navigation.NavigateTo($"/patients/{PatientId}/notes/tree");
    }

    private async Task OpenNewNoteDialog()
    {
        var parameters = new DialogParameters
        {
            ["PatientId"] = PatientId,
            ["IsEdit"] = false
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ClinicalNoteDialog>("New Clinical Note", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadNotes();
        }
    }

    private async Task ViewNote(ClinicalNote note)
    {
        var parameters = new DialogParameters
        {
            ["Note"] = note,
            ["IsViewOnly"] = true
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        await DialogService.ShowAsync<ClinicalNoteDialog>("Clinical Note", parameters, options);
    }

    private async Task EditNote(ClinicalNote note)
    {
        var parameters = new DialogParameters
        {
            ["PatientId"] = PatientId,
            ["Note"] = note,
            ["IsEdit"] = true
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ClinicalNoteDialog>("Edit Clinical Note", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadNotes();
        }
    }

    private async Task DeleteNote(ClinicalNote note)
    {
        var result = await DialogService.ShowMessageBox(
            "Delete Note",
            $"Are you sure you want to delete this clinical note? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel",
            options: new DialogOptions { MaxWidth = MaxWidth.Small }
        );

        if (result == true)
        {
            await ClinicalDataService.DeleteNoteAsync(note.Id);
            await LoadNotes();
        }
    }

    private async Task SignNote(ClinicalNote note)
    {
        note.SignedAt = DateTime.UtcNow;
        note.Status = NoteStatus.Signed;

        await ClinicalDataService.UpdateNoteAsync(note);
        await LoadNotes();
    }

    private bool CanSignNote()
    {
        return AuthState.CurrentUser?.Role == UserRole.Physician ||
               AuthState.CurrentUser?.Role == UserRole.Nurse ||
               AuthState.CurrentUser?.Role == UserRole.MedicalAssistant;
    }

    private Color GetNoteStatusColor(NoteStatus status)
    {
        return status switch
        {
            NoteStatus.InProgress => Color.Warning,
            NoteStatus.Signed => Color.Success,
            NoteStatus.Addended => Color.Info,
            NoteStatus.Cosigned => Color.Primary,
            _ => Color.Default
        };
    }
}
