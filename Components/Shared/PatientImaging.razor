@inject MockClinicalDataService ClinicalDataService

<MudCard Elevation="2">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Imaging Studies</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">
                Order Imaging
            </MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent Class="pa-0">
        @if (_studies.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="ma-4">No imaging studies on file</MudAlert>
        }
        else
        {
            <MudTable Items="@_studies" Hover="true" Dense="true">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Modality</MudTh>
                    <MudTh>Body Part</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Ordering Provider</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.StudyDate.ToString("MM/dd/yyyy")</MudTd>
                    <MudTd DataLabel="Modality">
                        <MudChip T="string" Size="Size.Small" Color="@GetModalityColor(context.Modality)">@context.Modality</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Body Part">@context.BodyPart</MudTd>
                    <MudTd DataLabel="Description">@context.Description</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Provider">@context.OrderingProvider</MudTd>
                    <MudTd>
                        @if (context.Status == ImagingStatus.Completed && !string.IsNullOrEmpty(context.Impression))
                        {
                            <MudTooltip Text="@context.Impression">
                                <MudIconButton Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Primary" />
                            </MudTooltip>
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Class="pa-4">No imaging studies found</MudText>
                </NoRecordsContent>
            </MudTable>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public int PatientId { get; set; }

    private List<ImagingStudy> _studies = new();

    protected override async Task OnParametersSetAsync()
    {
        _studies = await ClinicalDataService.GetImagingByPatientAsync(PatientId);
    }

    private Color GetModalityColor(string modality) => modality switch
    {
        "X-Ray" => Color.Info,
        "CT" => Color.Warning,
        "MRI" => Color.Primary,
        "Ultrasound" => Color.Success,
        "PET" => Color.Secondary,
        _ => Color.Default
    };

    private Color GetStatusColor(ImagingStatus status) => status switch
    {
        ImagingStatus.Completed => Color.Success,
        ImagingStatus.Scheduled => Color.Info,
        ImagingStatus.InProgress => Color.Warning,
        ImagingStatus.Ordered => Color.Default,
        ImagingStatus.Cancelled => Color.Error,
        _ => Color.Default
    };
}
